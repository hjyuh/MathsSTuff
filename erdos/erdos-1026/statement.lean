import Mathlib\n\nopen scoped BigOperators\n\nnamespace Erdos1026\n\n/-- `x` is strictly increasing on the finite index set `s` with respect to index order. -/\ndef StrictIncOn\n    {n : ℕ} (x : Fin n → ℝ) (s : Finset (Fin n)) : Prop :=\n  ∀ ⦃i j : Fin n⦄, i ∈ s -> j ∈ s -> i < j -> x i < x j\n\n/-- `x` is strictly decreasing on the finite index set `s` with respect to index order. -/\ndef StrictDecOn\n    {n : ℕ} (x : Fin n → ℝ) (s : Finset (Fin n)) : Prop :=\n  ∀ ⦃i j : Fin n⦄, i ∈ s -> j ∈ s -> i < j -> x j < x i\n\n/-- `x` is monotone on `s` if it is either strictly increasing or strictly decreasing. -/\ndef MonotoneOn\n    {n : ℕ} (x : Fin n → ℝ) (s : Finset (Fin n)) : Prop :=\n  StrictIncOn x s ∨ StrictDecOn x s\n\n/-- Target predicate for Erdos problem 1026. -/\ndef LargeMonotoneSubsequence\n    (k : ℕ) (x : Fin (k ^ 2) → ℝ) : Prop :=\n  ∃ s : Finset (Fin (k ^ 2)),\n    s.Nonempty ∧\n    MonotoneOn x s ∧\n    1 / (k : ℝ) ≤ ∑ i ∈ s, x i\n\n/-- Full problem statement in Lean form. -/\ndef Erdos1026Statement\n    (k : ℕ) (x : Fin (k ^ 2) → ℝ) : Prop :=\n  1 ≤ k ->\n  (∀ i, 0 < x i) ->\n  Function.Injective x ->\n  (∑ i, x i = 1) ->\n  LargeMonotoneSubsequence k x\n\ntheorem empty_sum_nonneg\n    (k : ℕ) (x : Fin (k ^ 2) → ℝ) :\n    0 ≤ (∑ i ∈ (∅ : Finset (Fin (k ^ 2))), x i) := by\n  simp\n\ntheorem singleton_is_monotone\n    (k : ℕ) (x : Fin (k ^ 2) → ℝ) (i : Fin (k ^ 2)) :\n    MonotoneOn x ({i} : Finset (Fin (k ^ 2))) := by\n  left\n  intro a b ha hb hab\n  have ha' : a = i := by simpa using ha\n  have hb' : b = i := by simpa using hb\n  subst ha'\n  subst hb'\n  exact (lt_irrefl _ hab).elim\n\n/-- Finite Cauchy-Schwarz specialized to the `k^2`-term normalization in the problem. -/\nlemma sum_sq_lower_bound\n    (k : ℕ)\n    (hk : 1 ≤ k)\n    (x : Fin (k ^ 2) → ℝ)\n    (hsum : ∑ i, x i = 1) :\n    1 / (k : ℝ) ^ 2 ≤ ∑ i, (x i) ^ 2 := by\n  have hsq : (1 : ℝ) ≤ (k ^ 2 : ℝ) * ∑ i, (x i) ^ 2 := by\n    calc\n      (1 : ℝ) = (∑ i, x i) ^ 2 := by\n        rw [hsum]\n        norm_num\n      _ ≤ (k ^ 2 : ℝ) * ∑ i, (x i) ^ 2 := by\n        simpa using sq_sum_le_card_mul_sum_sq (s := Finset.univ) (f := x)\n  have hkpos : 0 < (k : ℝ) ^ 2 := by\n    have : 0 < (k : ℝ) := by\n      exact_mod_cast (lt_of_lt_of_le (by decide : 0 < 1) hk)\n    positivity\n  by_contra h\n  have hlt : ∑ i, (x i) ^ 2 < 1 / (k : ℝ) ^ 2 := by\n    linarith\n  have hmul := mul_lt_mul_of_pos_left hlt hkpos\n  have hmul' : (k : ℝ) ^ 2 * ∑ i, (x i) ^ 2 < 1 := by\n    simpa [hkpos.ne', mul_assoc, one_div] using hmul\n  linarith\n\n/-- If one term already has weight at least `1 / k`, the problem is solved immediately. -/\nlemma large_entry_gives_large_monotone_subsequence\n    (k : ℕ)\n    (x : Fin (k ^ 2) → ℝ)\n    (i : Fin (k ^ 2))\n    (hi : 1 / (k : ℝ) ≤ x i) :\n    LargeMonotoneSubsequence k x := by\n  refine ⟨{i}, by simp, singleton_is_monotone k x i, ?_⟩\n  simpa using hi\n\n/--\nA finite subsequence `s` ends at index `i` when `i ∈ s`\nand every index in `s` is at most `i`.\n-/\ndef EndsAt {n : ℕ} (s : Finset (Fin n)) (i : Fin n) : Prop :=\n  i ∈ s ∧ ∀ ⦃j : Fin n⦄, j ∈ s -> j ≤ i\n\n/-- Candidate increasing subsequences ending at `i`. -/\nnoncomputable def IncScoreSets {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : Finset (Finset (Fin n)) :=\n  (Finset.powerset Finset.univ).filter fun s => StrictIncOn x s ∧ EndsAt s i\n\n/-- Candidate decreasing subsequences ending at `i`. -/\nnoncomputable def DecScoreSets {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : Finset (Finset (Fin n)) :=\n  (Finset.powerset Finset.univ).filter fun s => StrictDecOn x s ∧ EndsAt s i\n\nlemma singleton_mem_IncScoreSets {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    ({i} : Finset (Fin n)) ∈ IncScoreSets x i := by\n  simp [IncScoreSets, EndsAt, StrictIncOn]\n\nlemma singleton_mem_DecScoreSets {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    ({i} : Finset (Fin n)) ∈ DecScoreSets x i := by\n  simp [DecScoreSets, EndsAt, StrictDecOn]\n\n/-- Maximum weight of an increasing subsequence ending at `i`. -/\nnoncomputable def incScore {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : ℝ :=\n  sSup ((IncScoreSets x i).image fun s => ∑ j ∈ s, x j)\n\n/-- Maximum weight of a decreasing subsequence ending at `i`. -/\nnoncomputable def decScore {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : ℝ :=\n  sSup ((DecScoreSets x i).image fun s => ∑ j ∈ s, x j)\n\nlemma self_le_incScore {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : x i ≤ incScore x i := by\n  have hmem : x i ∈ ((IncScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) := by\n    refine Finset.mem_image.mpr ?_\n    refine ⟨{i}, singleton_mem_IncScoreSets x i, ?_⟩\n    simp\n  have hbd : BddAbove (((IncScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) : Set ℝ) := by\n    exact Set.Finite.bddAbove\n      (((IncScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ).finite_toSet)\n  exact le_csSup hbd hmem\n\nlemma self_le_decScore {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : x i ≤ decScore x i := by\n  have hmem : x i ∈ ((DecScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) := by\n    refine Finset.mem_image.mpr ?_\n    refine ⟨{i}, singleton_mem_DecScoreSets x i, ?_⟩\n    simp\n  have hbd : BddAbove (((DecScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) : Set ℝ) := by\n    exact Set.Finite.bddAbove\n      (((DecScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ).finite_toSet)\n  exact le_csSup hbd hmem\n\nlemma incScore_mem_finset {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    incScore x i ∈ ((IncScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) := by\n  let t : Finset ℝ := (IncScoreSets x i).image fun s => ∑ j ∈ s, x j\n  have htne : t.Nonempty := by\n    refine ⟨x i, ?_⟩\n    refine Finset.mem_image.mpr ?_\n    exact ⟨{i}, singleton_mem_IncScoreSets x i, by simp⟩\n  have hfin : (↑t : Set ℝ).Finite := t.finite_toSet\n  have htne_set : ((↑t : Set ℝ)).Nonempty := Finset.coe_nonempty.mpr htne\n  have hs : sSup (↑t : Set ℝ) ∈ (↑t : Set ℝ) := htne_set.csSup_mem hfin\n  simpa [incScore, t] using hs\n\nlemma decScore_mem_finset {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    decScore x i ∈ ((DecScoreSets x i).image fun s => ∑ j ∈ s, x j : Finset ℝ) := by\n  let t : Finset ℝ := (DecScoreSets x i).image fun s => ∑ j ∈ s, x j\n  have htne : t.Nonempty := by\n    refine ⟨x i, ?_⟩\n    refine Finset.mem_image.mpr ?_\n    exact ⟨{i}, singleton_mem_DecScoreSets x i, by simp⟩\n  have hfin : (↑t : Set ℝ).Finite := t.finite_toSet\n  have htne_set : ((↑t : Set ℝ)).Nonempty := Finset.coe_nonempty.mpr htne\n  have hs : sSup (↑t : Set ℝ) ∈ (↑t : Set ℝ) := htne_set.csSup_mem hfin\n  simpa [decScore, t] using hs\n\nlemma insert_mem_IncScoreSets_of_lt\n    {n : ℕ} {x : Fin n → ℝ} {s : Finset (Fin n)} {i j : Fin n}\n    (hs : s ∈ IncScoreSets x i)\n    (hij : i < j)\n    (hval : x i < x j) :\n    insert j s ∈ IncScoreSets x j := by\n  rcases Finset.mem_filter.mp hs with ⟨_, ⟨hsinc, hends⟩⟩\n  refine Finset.mem_filter.mpr ?_\n  refine ⟨by simp, ?_⟩\n  refine ⟨?_, ?_⟩\n  · intro a b ha hb hab\n    by_cases haj : a = j\n    · have hb' : b ∈ s := by\n        rcases Finset.mem_insert.mp hb with hbj | hbs\n        · have : a = b := by simpa [haj] using hbj.symm\n          exact (ne_of_lt hab this).elim\n        · exact hbs\n      have hb_lt_j : b < j := lt_of_le_of_lt (hends.2 hb') hij\n      exact (not_lt_of_ge (by simpa [haj] using hb_lt_j.le) hab).elim\n    · by_cases hbj : b = j\n      · have ha' : a ∈ s := by\n          rcases Finset.mem_insert.mp ha with h | h\n          · exact (haj h).elim\n          · exact h\n        have hai_le : a ≤ i := hends.2 ha'\n        rcases lt_or_eq_of_le hai_le with hlt | heq\n        · simpa [hbj] using lt_trans (hsinc ha' hends.1 hlt) hval\n        · simpa [heq, hbj] using hval\n      · have ha' : a ∈ s := by\n          rcases Finset.mem_insert.mp ha with h | h\n          · exact (haj h).elim\n          · exact h\n        have hb' : b ∈ s := by\n          rcases Finset.mem_insert.mp hb with h | h\n          · exact (hbj h).elim\n          · exact h\n        exact hsinc ha' hb' hab\n  · refine ⟨by simp, ?_⟩\n    intro a ha\n    rcases Finset.mem_insert.mp ha with rfl | has\n    · exact le_rfl\n    · exact le_trans (hends.2 has) hij.le\n\nlemma insert_mem_DecScoreSets_of_lt\n    {n : ℕ} {x : Fin n → ℝ} {s : Finset (Fin n)} {i j : Fin n}\n    (hs : s ∈ DecScoreSets x i)\n    (hij : i < j)\n    (hval : x j < x i) :\n    insert j s ∈ DecScoreSets x j := by\n  rcases Finset.mem_filter.mp hs with ⟨_, ⟨hsdec, hends⟩⟩\n  refine Finset.mem_filter.mpr ?_\n  refine ⟨by simp, ?_⟩\n  refine ⟨?_, ?_⟩\n  · intro a b ha hb hab\n    by_cases haj : a = j\n    · have hb' : b ∈ s := by\n        rcases Finset.mem_insert.mp hb with hbj | hbs\n        · have : a = b := by simpa [haj] using hbj.symm\n          exact (ne_of_lt hab this).elim\n        · exact hbs\n      have hb_lt_j : b < j := lt_of_le_of_lt (hends.2 hb') hij\n      exact (not_lt_of_ge (by simpa [haj] using hb_lt_j.le) hab).elim\n    · by_cases hbj : b = j\n      · have ha' : a ∈ s := by\n          rcases Finset.mem_insert.mp ha with h | h\n          · exact (haj h).elim\n          · exact h\n        have hai_le : a ≤ i := hends.2 ha'\n        rcases lt_or_eq_of_le hai_le with hlt | heq\n        · simpa [hbj] using lt_trans hval (hsdec ha' hends.1 hlt)\n        · simpa [heq, hbj] using hval\n      · have ha' : a ∈ s := by\n          rcases Finset.mem_insert.mp ha with h | h\n          · exact (haj h).elim\n          · exact h\n        have hb' : b ∈ s := by\n          rcases Finset.mem_insert.mp hb with h | h\n          · exact (hbj h).elim\n          · exact h\n        exact hsdec ha' hb' hab\n  · refine ⟨by simp, ?_⟩\n    intro a ha\n    rcases Finset.mem_insert.mp ha with rfl | has\n    · exact le_rfl\n    · exact le_trans (hends.2 has) hij.le\n\nlemma incScore_step_of_lt\n    {n : ℕ} (x : Fin n → ℝ) {i j : Fin n}\n    (hij : i < j) (hval : x i < x j) :\n    incScore x i + x j ≤ incScore x j := by\n  rcases Finset.mem_image.mp (incScore_mem_finset x i) with ⟨s, hs, hsEq⟩\n  have hsj : insert j s ∈ IncScoreSets x j := insert_mem_IncScoreSets_of_lt hs hij hval\n  have hnot : j ∉ s := by\n    rcases Finset.mem_filter.mp hs with ⟨_, ⟨_, hends⟩⟩\n    intro hmem\n    exact (not_lt_of_ge (hends.2 hmem) hij).elim\n  have hmem :\n      ∑ k ∈ insert j s, x k ∈\n        ((IncScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ) := by\n    refine Finset.mem_image.mpr ?_\n    exact ⟨insert j s, hsj, rfl⟩\n  have hbd : BddAbove ((((IncScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ) : Set ℝ)) := by\n    exact Set.Finite.bddAbove\n      (((IncScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ).finite_toSet)\n  have hle : ∑ k ∈ insert j s, x k ≤ incScore x j := le_csSup hbd hmem\n  simpa [hsEq, Finset.sum_insert, hnot, add_comm, add_left_comm, add_assoc] using hle\n\nlemma decScore_step_of_lt\n    {n : ℕ} (x : Fin n → ℝ) {i j : Fin n}\n    (hij : i < j) (hval : x j < x i) :\n    decScore x i + x j ≤ decScore x j := by\n  rcases Finset.mem_image.mp (decScore_mem_finset x i) with ⟨s, hs, hsEq⟩\n  have hsj : insert j s ∈ DecScoreSets x j := insert_mem_DecScoreSets_of_lt hs hij hval\n  have hnot : j ∉ s := by\n    rcases Finset.mem_filter.mp hs with ⟨_, ⟨_, hends⟩⟩\n    intro hmem\n    exact (not_lt_of_ge (hends.2 hmem) hij).elim\n  have hmem :\n      ∑ k ∈ insert j s, x k ∈\n        ((DecScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ) := by\n    refine Finset.mem_image.mpr ?_\n    exact ⟨insert j s, hsj, rfl⟩\n  have hbd : BddAbove ((((DecScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ) : Set ℝ)) := by\n    exact Set.Finite.bddAbove\n      (((DecScoreSets x j).image fun s => ∑ k ∈ s, x k : Finset ℝ).finite_toSet)\n  have hle : ∑ k ∈ insert j s, x k ≤ decScore x j := le_csSup hbd hmem\n  simpa [hsEq, Finset.sum_insert, hnot, add_comm, add_left_comm, add_assoc] using hle\n\nlemma score_step_of_injective\n    {n : ℕ} (x : Fin n → ℝ) (hinj : Function.Injective x) {i j : Fin n}\n    (hij : i < j) :\n    incScore x i + x j ≤ incScore x j ∨ decScore x i + x j ≤ decScore x j := by\n  have hne : x i ≠ x j := by\n    intro hEq\n    exact hij.ne (hinj hEq)\n  rcases lt_or_gt_of_ne hne with hlt | hgt\n  · exact Or.inl (incScore_step_of_lt x hij hlt)\n  · exact Or.inr (decScore_step_of_lt x hij hgt)\n\nlemma exists_incScore_witness {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    ∃ s : Finset (Fin n), s ∈ IncScoreSets x i ∧ ∑ j ∈ s, x j = incScore x i := by\n  rcases Finset.mem_image.mp (incScore_mem_finset x i) with ⟨s, hs, hsum⟩\n  exact ⟨s, hs, by simpa using hsum⟩\n\nlemma exists_decScore_witness {n : ℕ} (x : Fin n → ℝ) (i : Fin n) :\n    ∃ s : Finset (Fin n), s ∈ DecScoreSets x i ∧ ∑ j ∈ s, x j = decScore x i := by\n  rcases Finset.mem_image.mp (decScore_mem_finset x i) with ⟨s, hs, hsum⟩\n  exact ⟨s, hs, by simpa using hsum⟩\n\n/-- The horizontal interval attached to index `i` in the packing argument. -/\ndef incInterval {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : Set ℝ :=\n  Set.Ioc (incScore x i - x i) (incScore x i)\n\n/-- The vertical interval attached to index `i` in the packing argument. -/\ndef decInterval {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : Set ℝ :=\n  Set.Ioc (decScore x i - x i) (decScore x i)\n\n/-- The rectangle attached to index `i` in the weighted Seidenberg packing proof. -/\ndef scoreBox {n : ℕ} (x : Fin n → ℝ) (i : Fin n) : Set (ℝ × ℝ) :=\n  incInterval x i ×ˢ decInterval x i\n\nlemma disjoint_prod_left {α β : Type*} {s₁ s₂ : Set α} {t₁ t₂ : Set β}\n    (h : Disjoint s₁ s₂) :\n    Disjoint (s₁ ×ˢ t₁) (s₂ ×ˢ t₂) := by\n  rw [Set.disjoint_left] at h ⊢\n  intro p hp₁ hp₂\n  exact h hp₁.1 hp₂.1\n\nlemma disjoint_prod_right {α β : Type*} {s₁ s₂ : Set α} {t₁ t₂ : Set β}\n    (h : Disjoint t₁ t₂) :\n    Disjoint (s₁ ×ˢ t₁) (s₂ ×ˢ t₂) := by\n  rw [Set.disjoint_left] at h ⊢\n  intro p hp₁ hp₂\n  exact h hp₁.2 hp₂.2\n\nlemma scoreBox_disjoint\n    {n : ℕ} (x : Fin n → ℝ) (hinj : Function.Injective x) {i j : Fin n}\n    (hij : i ≠ j) :\n    Disjoint (scoreBox x i) (scoreBox x j) := by\n  rcases lt_or_gt_of_ne hij with hij_lt | hij_gt\n  · rcases score_step_of_injective x hinj hij_lt with hinc | hdec\n    · have hinc' : incScore x i ≤ incScore x j - x j := by\n        linarith\n      rw [scoreBox]\n      exact disjoint_prod_left (t₁ := decInterval x i) (t₂ := decInterval x j)\n        (Set.Ioc_disjoint_Ioc_of_le hinc')\n    · have hdec' : decScore x i ≤ decScore x j - x j := by\n        linarith\n      rw [scoreBox]\n      exact disjoint_prod_right (s₁ := incInterval x i) (s₂ := incInterval x j)\n        (Set.Ioc_disjoint_Ioc_of_le hdec')\n  · have hji : Disjoint (scoreBox x j) (scoreBox x i) := by\n      rcases score_step_of_injective x hinj hij_gt with hinc | hdec\n      · have hinc' : incScore x j ≤ incScore x i - x i := by\n          linarith\n        rw [scoreBox]\n        exact disjoint_prod_left (t₁ := decInterval x j) (t₂ := decInterval x i)\n          (Set.Ioc_disjoint_Ioc_of_le hinc')\n      · have hdec' : decScore x j ≤ decScore x i - x i := by\n          linarith\n        rw [scoreBox]\n        exact disjoint_prod_right (s₁ := incInterval x j) (s₂ := incInterval x i)\n          (Set.Ioc_disjoint_Ioc_of_le hdec')\n    exact hji.symm\n\nlemma scoreBox_subset_bigBox {n : ℕ} (x : Fin n → ℝ) (L D : ℝ)\n    (hL : ∀ i, incScore x i ≤ L)\n    (hD : ∀ i, decScore x i ≤ D) :\n    (⋃ i, scoreBox x i) ⊆ Set.Ioc (0 : ℝ) L ×ˢ Set.Ioc (0 : ℝ) D := by\n  intro p hp\n  rcases Set.mem_iUnion.mp hp with ⟨i, hi⟩\n  have hi' : p ∈ incInterval x i ×ˢ decInterval x i := by\n    simpa [scoreBox] using hi\n  rcases hi' with ⟨hi₁, hi₂⟩\n  have hleft : 0 ≤ incScore x i - x i := sub_nonneg.mpr (self_le_incScore x i)\n  have hdown : 0 ≤ decScore x i - x i := sub_nonneg.mpr (self_le_decScore x i)\n  refine ⟨?_, ?_⟩\n  · exact ⟨lt_of_le_of_lt hleft hi₁.1, le_trans hi₁.2 (hL i)⟩\n  · exact ⟨lt_of_le_of_lt hdown hi₂.1, le_trans hi₂.2 (hD i)⟩\n\nlemma volume_scoreBox {n : ℕ} (x : Fin n → ℝ) (i : Fin n) (hx : 0 ≤ x i) :\n    MeasureTheory.volume (scoreBox x i) = ENNReal.ofReal ((x i) ^ 2) := by\n  rw [scoreBox, MeasureTheory.Measure.volume_eq_prod, MeasureTheory.Measure.prod_prod]\n  simp [incInterval, decInterval, hx]\n  ring\n\nlemma volume_bigBox (L D : ℝ) (hL : 0 ≤ L) :\n    MeasureTheory.volume (Set.Ioc (0 : ℝ) L ×ˢ Set.Ioc (0 : ℝ) D) = ENNReal.ofReal (L * D) := by\n  rw [MeasureTheory.Measure.volume_eq_prod, MeasureTheory.Measure.prod_prod]\n  simp [hL]\n\n/-- The weighted Erdos-Szekeres statement for Erdos problem 1026. -/\ntheorem erdos_1026\n    (k : ℕ)\n    (hk : 1 ≤ k)\n    (x : Fin (k ^ 2) → ℝ)\n    (hpos : ∀ i, 0 < x i)\n    (hinj : Function.Injective x)\n    (hsum : ∑ i, x i = 1) :\n    LargeMonotoneSubsequence k x := by\n  have hk2pos : 0 < k ^ 2 := by\n    have hkpos : 0 < k := Nat.succ_le_iff.mp hk\n    exact pow_pos hkpos 2\n  have huniv_nonempty : (Finset.univ : Finset (Fin (k ^ 2))).Nonempty := by\n    exact ⟨⟨0, hk2pos⟩, Finset.mem_univ _⟩\n  obtain ⟨iL, -, hLmax_raw⟩ :=\n    Finset.exists_max_image\n      (Finset.univ : Finset (Fin (k ^ 2))) (fun i => incScore x i) huniv_nonempty\n  obtain ⟨iD, -, hDmax_raw⟩ :=\n    Finset.exists_max_image\n      (Finset.univ : Finset (Fin (k ^ 2))) (fun i => decScore x i) huniv_nonempty\n  have hLmax : ∀ i, incScore x i ≤ incScore x iL := by\n    intro i\n    exact hLmax_raw i (Finset.mem_univ i)\n  have hDmax : ∀ i, decScore x i ≤ decScore x iD := by\n    intro i\n    exact hDmax_raw i (Finset.mem_univ i)\n  have hpair :\n      ((↑(Finset.univ : Finset (Fin (k ^ 2))) : Set (Fin (k ^ 2))))\n        .PairwiseDisjoint (scoreBox x) := by\n    intro i hi j hj hij\n    exact scoreBox_disjoint x hinj hij\n  have hmeas : ∀ i ∈ (Finset.univ : Finset (Fin (k ^ 2))), MeasurableSet (scoreBox x i) := by\n    intro i hi\n    simpa [scoreBox] using measurableSet_Ioc.prod measurableSet_Ioc\n  have hsubset :\n      (⋃ i ∈ (Finset.univ : Finset (Fin (k ^ 2))), scoreBox x i) ⊆ ⋃ i, scoreBox x i := by\n    intro p hp\n    rcases Set.mem_iUnion₂.mp hp with ⟨i, -, hi⟩\n    exact Set.mem_iUnion.mpr ⟨i, hi⟩\n  have harea :\n      ∑ i, MeasureTheory.volume (scoreBox x i) ≤\n        MeasureTheory.volume\n          (Set.Ioc (0 : ℝ) (incScore x iL) ×ˢ\n            Set.Ioc (0 : ℝ) (decScore x iD)) := by\n    calc\n      ∑ i, MeasureTheory.volume (scoreBox x i)\n          = MeasureTheory.volume (⋃ i ∈ (Finset.univ : Finset (Fin (k ^ 2))), scoreBox x i) := by\n              symm\n              simpa using (MeasureTheory.measure_biUnion_finset hpair hmeas)\n      _ ≤ MeasureTheory.volume (⋃ i, scoreBox x i) := by\n            exact MeasureTheory.measure_mono hsubset\n      _ ≤ MeasureTheory.volume\n            (Set.Ioc (0 : ℝ) (incScore x iL) ×ˢ\n              Set.Ioc (0 : ℝ) (decScore x iD)) := by\n            exact MeasureTheory.measure_mono\n              (scoreBox_subset_bigBox x (incScore x iL) (decScore x iD) hLmax hDmax)\n  have hLpos : 0 ≤ incScore x iL := le_trans (le_of_lt (hpos iL)) (self_le_incScore x iL)\n  have hDpos : 0 ≤ decScore x iD := le_trans (le_of_lt (hpos iD)) (self_le_decScore x iD)\n  have htop :\n      MeasureTheory.volume\n        (Set.Ioc (0 : ℝ) (incScore x iL) ×ˢ\n          Set.Ioc (0 : ℝ) (decScore x iD)) ≠ ⊤ := by\n    rw [volume_bigBox (incScore x iL) (decScore x iD) hLpos]\n    simp\n  have harea_real := ENNReal.toReal_mono htop harea\n  have hleft :\n      (∑ i, MeasureTheory.volume (scoreBox x i)).toReal = ∑ i, (x i) ^ 2 := by\n    rw [ENNReal.toReal_sum]\n    · refine Finset.sum_congr rfl ?_\n      intro i hi\n      rw [volume_scoreBox x i (le_of_lt (hpos i)), ENNReal.toReal_ofReal]\n      positivity\n    · intro i hi\n      rw [volume_scoreBox x i (le_of_lt (hpos i))]\n      simp\n  have hright :\n      (MeasureTheory.volume\n        (Set.Ioc (0 : ℝ) (incScore x iL) ×ˢ\n          Set.Ioc (0 : ℝ) (decScore x iD))).toReal =\n        incScore x iL * decScore x iD := by\n    rw [volume_bigBox (incScore x iL) (decScore x iD) hLpos, ENNReal.toReal_ofReal]\n    exact mul_nonneg hLpos hDpos\n  rw [hleft, hright] at harea_real\n  have hprod : 1 / (k : ℝ) ^ 2 ≤ incScore x iL * decScore x iD := by\n    exact le_trans (sum_sq_lower_bound k hk x hsum) harea_real\n  have hlarge : 1 / (k : ℝ) ≤ incScore x iL ∨ 1 / (k : ℝ) ≤ decScore x iD := by\n    by_contra hsmall\n    push_neg at hsmall\n    have hmul : incScore x iL * decScore x iD < (1 / (k : ℝ)) * (1 / (k : ℝ)) := by\n      exact mul_lt_mul'' hsmall.1 hsmall.2 hLpos hDpos\n    have : incScore x iL * decScore x iD < 1 / (k : ℝ) ^ 2 := by\n      simpa [pow_two, one_div, mul_comm, mul_left_comm, mul_assoc] using hmul\n    exact this.not_ge hprod\n  rcases hlarge with hinc | hdec\n  · rcases exists_incScore_witness x iL with ⟨s, hs, hscore⟩\n    rcases Finset.mem_filter.mp hs with ⟨_, ⟨hsmono, hends⟩⟩\n    refine ⟨s, ⟨iL, hends.1⟩, Or.inl hsmono, ?_⟩\n    simpa [hscore] using hinc\n  · rcases exists_decScore_witness x iD with ⟨s, hs, hscore⟩\n    rcases Finset.mem_filter.mp hs with ⟨_, ⟨hsmono, hends⟩⟩\n    refine ⟨s, ⟨iD, hends.1⟩, Or.inr hsmono, ?_⟩\n    simpa [hscore] using hdec\n\n/-- The packaged statement now follows immediately from `erdos_1026`. -/\ntheorem erdos1026_statement_holds\n    (k : ℕ)\n    (x : Fin (k ^ 2) → ℝ) :\n    Erdos1026Statement k x := by\n  intro hk hpos hinj hsum\n  exact erdos_1026 k hk x hpos hinj hsum\n\nend Erdos1026\n